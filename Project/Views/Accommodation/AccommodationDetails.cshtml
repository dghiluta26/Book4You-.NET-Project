@model Project.Models.AccommodationDetailsViewModel

@{
    ViewData["Title"] = Model.Accommodation.Title;
}

<main class="page">
    <section class="page-hero">
        <h1>@Model.Accommodation.Title</h1>
        <p>@Model.Accommodation.Location</p>
    </section>

    <section class="accommodation-details-section">
        @Html.AntiForgeryToken()
        <div class="accommodation-details-container">

            <div class="details-image-wrapper">
                @{
                    var mainImage = Model.Images.FirstOrDefault(i => i.IsMain) ?? Model.Images.FirstOrDefault();
                    var mainImageUrl = mainImage != null ? mainImage.ImageUrl : Model.Accommodation.ImageUrl;
                }

                <img id="mainAccommodationImage" src="@mainImageUrl" alt="@Model.Accommodation.Title" class="details-main-image" />

                @if (Model.Images != null && Model.Images.Any())
                {
                    <div class="details-thumbnail-gallery">
                        @foreach (var image in Model.Images)
                        {
                            <img src="@image.ImageUrl"
                                 alt="@Model.Accommodation.Title"
                                 class="details-thumbnail @(image.ImageUrl == mainImageUrl ? "active-thumbnail" : "")"
                                 onclick="changeAccommodationImage('@image.ImageUrl', this)" />
                        }
                    </div>
                }
            </div>

            <div class="details-content">
                <div class="details-top-row">
                    <div>
                        <h2>@Model.Accommodation.Title</h2>
                        <p class="details-location">@Model.Accommodation.Location</p>
                    </div>

                    <div class="details-rating">
                        ★ @Model.Accommodation.Rating
                    </div>
                </div>

                <p class="details-description">
                    @Model.Accommodation.Description
                </p>

                <div class="details-info-grid">
                    <div class="details-info-card">
                        <span class="details-label">Type</span>
                        <strong>@Model.Accommodation.Type</strong>
                    </div>

                    <div class="details-info-card">
                        <span class="details-label">Guests</span>
                        <strong>@Model.Accommodation.Capacity</strong>
                    </div>

                    <div class="details-info-card">
                        <span class="details-label">Bedrooms</span>
                        <strong>@Model.Accommodation.Bedrooms</strong>
                    </div>

                    <div class="details-info-card">
                        <span class="details-label">Bathrooms</span>
                        <strong>@Model.Accommodation.Bathrooms</strong>
                    </div>
                </div>

                <div class="details-price-box">
                    <div>
                        <span class="details-price-label">Price per night</span>
                        <div class="details-price">€@Model.Accommodation.PricePerNight</div>
                    </div>

                    <div style="display:flex; gap:8px; align-items:center;">
                        <div style="display:flex; gap:8px; align-items:center;">
                            <label style="color:#666;">Guests</label>
                            <input type="number" id="bookGuests" min="1" max="@Model.Accommodation.Capacity" value="1" style="width:70px; padding:6px; border-radius:6px; border:1px solid #ddd;" />
                        </div>

                        <div style="display:flex; gap:8px; align-items:center;">
                            <label style="color:#666;">Check-in</label>
                            <input type="date" id="bookCheckIn" value="@ViewBag.CheckIn" />
                        </div>

                        <div style="display:flex; gap:8px; align-items:center;">
                            <label style="color:#666;">Check-out</label>
                            <input type="date" id="bookCheckOut" value="@ViewBag.CheckOut" />
                        </div>

                        <a href="#" class="details-book-btn" id="bookNowBtn" data-accommodation-id="@Model.Accommodation.Id">Book Now</a>
                        <div id="bookingError" class="error-container" style="color:red; display:none; margin-left:8px;"></div>
                    </div>
                </div>

                <div class="details-amenities">
                    <h3>Amenities</h3>

                    @if (Model.Amenities == null || !Model.Amenities.Any())
                    {
                        <p class="no-amenities">No amenities listed for this accommodation yet.</p>
                    }
                    else
                    {
                        <div class="amenities-list">
                            @foreach (var amenity in Model.Amenities)
                            {
                                <span class="amenity-badge">@amenity.Name</span>
                            }
                        </div>
                    }
                </div>

                <div class="details-reviews">
                    <h3>Reviews</h3>

                    @if (TempData["ReviewSuccess"] != null)
                    {
                        <div class="success-container review-alert">
                            @TempData["ReviewSuccess"]
                        </div>
                    }

                    @if (TempData["ReviewError"] != null)
                    {
                        <div class="error-container review-alert">
                            @TempData["ReviewError"]
                        </div>
                    }

                    @if (Model.Reviews == null || !Model.Reviews.Any())
                    {
                        <p class="no-amenities">No reviews yet. Be the first to share your experience.</p>
                    }
                    else
                    {
                        <div class="reviews-list">
                            @foreach (var review in Model.Reviews)
                            {
                                <article class="review-card">
                                    <div class="review-card-header">
                                        <strong>@(review.User?.FirstName ?? "Guest") @(review.User?.LastName ?? string.Empty)</strong>
                                        <span class="accommodation-rating">★ @review.Rating</span>
                                    </div>
                                    <p class="review-date">@review.CreatedAt.ToString("dd MMM yyyy")</p>
                                    <p class="review-comment">@review.Comment</p>
                                </article>
                            }
                        </div>
                    }

                    @if (Model.CanLeaveReview)
                    {
                        <form asp-controller="Accommodation" asp-action="AddReview" method="post" class="review-form">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="accommodationId" value="@Model.Accommodation.Id" />

                            <label class="review-form-label">
                                Rating
                                <select name="rating" required class="review-input">
                                    <option value="5">5 - Excellent</option>
                                    <option value="4">4 - Very good</option>
                                    <option value="3">3 - Good</option>
                                    <option value="2">2 - Fair</option>
                                    <option value="1">1 - Poor</option>
                                </select>
                            </label>

                            <label class="review-form-label">
                                Comment
                                <textarea name="comment" rows="4" maxlength="1000" required placeholder="Share what you liked about your stay..." class="review-input"></textarea>
                            </label>

                            <button type="submit" class="details-book-btn review-submit-btn">Submit Review</button>
                        </form>
                    }
                    else if (User.Identity?.IsAuthenticated == true)
                    {
                        <p class="muted review-info-note">You can leave a review after your stay, or if you have already reviewed this accommodation, thank you for the feedback.</p>
                    }
                    else
                    {
                        <p class="muted review-info-note">Log in after your stay to leave a review.</p>
                    }
                </div>
            </div>

        </div>
    </section>
</main>

@section Scripts {
    <script>
        function changeAccommodationImage(imageUrl, clickedThumbnail) {
            const mainImage = document.getElementById("mainAccommodationImage");
            mainImage.src = imageUrl;

            const thumbnails = document.querySelectorAll(".details-thumbnail");
            thumbnails.forEach(t => t.classList.remove("active-thumbnail"));

            clickedThumbnail.classList.add("active-thumbnail");
        }

        document.addEventListener('DOMContentLoaded', function(){
            var bookBtn = document.getElementById('bookNowBtn');
            if(!bookBtn) return;

            bookBtn.addEventListener('click', function(e){
                e.preventDefault();
                var id = this.getAttribute('data-accommodation-id');
                var guests = document.getElementById('bookGuests')?.value || '1';
                var checkIn = document.getElementById('bookCheckIn')?.value || '';
                var checkOut = document.getElementById('bookCheckOut')?.value || '';

                fetch('@Url.Action("Book", "Booking")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                    },
                    body: 'id=' + encodeURIComponent(id) + '&guests=' + encodeURIComponent(guests) + '&checkIn=' + encodeURIComponent(checkIn) + '&checkOut=' + encodeURIComponent(checkOut)
                })
                .then(response => response.json())
                .then(data => {
                    var errEl = document.getElementById('bookingError');
                    if (!errEl) errEl = document.createElement('div');

                    if(data.success){
                        errEl.style.color = '#1b5e20';
                        errEl.style.display = 'block';
                        errEl.innerText = "You've successfully booked this accommodation!";
                        if(data.redirect) setTimeout(function(){ window.location = data.redirect; }, 900);
                    } else if (data.loginRedirect) {
                        window.location = data.loginRedirect;
                    } else {
                        errEl.style.color = '#b00020';
                        errEl.style.display = 'block';
                        errEl.innerText = data.message || 'Booking failed';
                    }
                })
                .catch(err => {
                    console.error(err);
                    var errEl = document.getElementById('bookingError');
                    if (errEl) {
                        errEl.style.color = '#b00020';
                        errEl.style.display = 'block';
                        errEl.innerText = 'An error occurred while booking.';
                    } else {
                        alert('An error occurred while booking.');
                    }
                });
            });
        });
    </script>
}