@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="page">
    <section class="page-hero">
        <h1>Privacy Policy</h1>
        <p>How we collect, use, and protect your information.</p>
    </section>

    <section class="privacy-section">
        <div class="privacy-container">
            <h2>1. Information We Collect</h2>
            <p>
                We may collect information you provide when using the website, such as your name, email address,
                and any message you send through the contact form. In this demo version, data is not stored on a server.
            </p>

            <h2>2. How We Use Your Information</h2>
            <p>In a real platform, your information may be used to:</p>
            <ul>
                <li>Create and manage user accounts</li>
                <li>Provide customer support</li>
                <li>Improve the website and user experience</li>
                <li>Send important updates (only when needed)</li>
            </ul>

            <h2>3. Cookies</h2>
            <p>
                Cookies are small files stored on your device. They help websites remember preferences and improve usability.
                In this frontend-only demo, cookies may not be used, but a real version may use them for session and analytics.
            </p>

            <h2>4. Data Sharing</h2>
            <p>
                We do not sell your personal data. In a production system, data may be shared only with trusted service providers
                and only when necessary to deliver the service.
            </p>

            <h2>5. Data Security</h2>
            <p>
                We take reasonable steps to protect personal information. However, no online service can guarantee absolute security.
            </p>

            <h2>6. Your Rights</h2>
            <ul>
                <li>Request access to your data</li>
                <li>Request correction or deletion</li>
                <li>Withdraw consent</li>
                <li>Request data portability</li>
            </ul>

            <h2>7. Changes to This Policy</h2>
            <p>
                We may update this policy from time to time. Changes will be posted on this page.
            </p>

            <h2>8. Contact</h2>
            <p>
                If you have questions about this Privacy Policy, contact us at
                <strong>support@book4you.com</strong>.
            </p>
        </div>
    </section>
</div>