@{
    ViewData["Title"] = "Home";
}

<section class="hero">
    <div class="hero-content">
        <h1>Find your perfect stay</h1>
        <p>Search deals on hotels, homes, and much more...</p>

        <form asp-controller="Accommodation" asp-action="Accommodations" method="get" class="search-box">
            <div class="search-field">
                <input type="text" name="location" placeholder="Where are you going?" />
            </div>

            <div class="search-field">
                <select name="type">
                    <option value="">All types</option>
                    <option value="Villa">Villa</option>
                    <option value="Apartment">Apartment</option>
                    <option value="Cabin">Cabin</option>
                    <option value="Studio">Studio</option>
                </select>
            </div>

            <div class="search-field">
                <input type="date" name="checkIn" />
            </div>

            <div class="search-field">
                <input type="date" name="checkOut" />
            </div>

            <div class="search-field guests-field">
                <input type="number" name="guests" placeholder="Guests" min="1" />
            </div>

            <button type="submit" class="search-btn">Search</button>
        </form>
    </div>
</section>