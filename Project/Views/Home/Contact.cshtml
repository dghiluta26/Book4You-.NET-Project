@model Project.Models.ContactMessage

@{
    ViewData["Title"] = "Contact";
}

<div class="page">
    <section class="contact-section">
        <div class="contact-container">
            <div class="contact-form-wrapper">
                <h2>Send us a message</h2>

                @if (TempData["ContactSuccess"] is string successMessage)
                {
                    <div class="text-success">@successMessage</div>
                }

                <form asp-controller="Home" asp-action="Contact" method="post" class="contact-form">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <label asp-for="Name"></label>
                    <input asp-for="Name" type="text" />
                    <span asp-validation-for="Name" class="text-danger"></span>

                    <label asp-for="Email"></label>
                    <input asp-for="Email" type="email" />
                    <span asp-validation-for="Email" class="text-danger"></span>

                    <label asp-for="Subject"></label>
                    <input asp-for="Subject" type="text" />
                    <span asp-validation-for="Subject" class="text-danger"></span>

                    <label asp-for="Message"></label>
                    <textarea asp-for="Message" rows="5"></textarea>
                    <span asp-validation-for="Message" class="text-danger"></span>

                    <button class="contact-btn" type="submit">Send message</button>
                </form>
            </div>

            <div class="contact-info">
                <h2>Contact info</h2>
                <p><strong>Email:</strong> support@book4you.com</p>
                <p><strong>Phone:</strong> +40 700 000 000</p>
                <p><strong>Hours:</strong> Mon–Fri, 09:00–18:00</p>

                <div class="map-container">
                    <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2855.0574175412557!2d23.832505175931683!3d44.30877010978519!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4752d702cd0f3173%3A0xb159446a3e899375!2sFacultatea%20de%20Automatic%C4%83%20%C8%99i%20Electronic%C4%83!5e0!3m2!1sro!2sro!4v1772979129731!5m2!1sro!2sro"
                            width="600"
                            height="450"
                            style="border:0;"
                            allowfullscreen=""
                            loading="lazy"
                            referrerpolicy="no-referrer-when-downgrade">
                    </iframe>
                </div>
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
