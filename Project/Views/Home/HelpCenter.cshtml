@{
    ViewData["Title"] = "Help Center";
}

<div class="page">
    <section class="page-hero">
        <h1>Help Center</h1>
        <p>Find answers to common questions about bookings, accounts, and support.</p>
    </section>

    <section class="info-page-section">
        <div class="info-page-container">
            <h2>Frequently asked questions</h2>

            <div class="info-page-card">
                <h3>How do I book a stay?</h3>
                <p>
                    Go to an accommodation page, select your guests and dates, then click <strong>Book Now</strong>.
                    If you are not signed in, you may be redirected to log in first.
                </p>
            </div>

            <div class="info-page-card">
                <h3>How can I view my bookings?</h3>
                <p>
                    After logging in, open the user menu in the top-right corner and choose <strong>My bookings</strong>.
                </p>
            </div>

            <div class="info-page-card">
                <h3>Can I leave a review?</h3>
                <p>
                    Reviews can be submitted after a completed stay. If you are eligible, the review form will appear
                    on the accommodation details page.
                </p>
            </div>

            <div class="info-page-card">
                <h3>Need more help?</h3>
                <p>
                    Use the <a asp-controller="Home" asp-action="Contact">Contact</a> page to send us a message and we will get back to you.
                </p>
            </div>
        </div>
    </section>
</div>