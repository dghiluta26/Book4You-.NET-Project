@{
    ViewData["Title"] = "About";
}

<div class="page">
    <section class="page-hero">
        <h1>About Book4You</h1>
        <p>We help people discover stays and plan trips faster, easier and smarter.</p>
    </section>

    <section class="about-section">
        <div class="about-container">
            <h2>Our Mission</h2>
            <p>
                Book4You was created with one goal in mind: to simplify the booking experience.
                We believe finding the perfect stay should be fast, transparent and stress-free.
            </p>

            <p>
                Our platform is designed to offer a clean interface, intuitive navigation,
                and a seamless user journey from search to reservation.
            </p>

            <h2>What We Offer</h2>
            <ul>
                <li>Fast and intuitive search experience</li>
                <li>Modern property detail pages</li>
                <li>Secure login and account system</li>
                <li>Responsive design across all devices</li>
            </ul>

            <h2>Our Vision</h2>
            <p>
                We aim to build a platform that feels professional, reliable and easy to use.
                Even though this project is currently frontend-focused, it is structured
                to be easily integrated with backend systems in the future.
            </p>

            <p>
                Book4You represents a modern approach to travel platforms —
                clean design, user-centered layout, and scalable structure.
            </p>
        </div>
    </section>
</div>