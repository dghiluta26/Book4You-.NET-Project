@{
    ViewData["Title"] = "About";
}

<div class="page">
    <section class="page-hero">
        <h1>About Book4You</h1>
        <p>We help people discover stays and plan trips faster, easier and smarter.</p>
    </section>

    <section class="info-page-section">
        <div class="info-page-container">
            <h2>Our mission</h2>

            <div class="info-page-card">
                <p>
                    Book4You was created with one goal in mind: to simplify the booking experience.
                    We believe finding the perfect stay should be fast, transparent and stress-free.
                </p>
            </div>

            <div class="info-page-card">
                <h3>What we offer</h3>
                <ul class="info-page-list">
                    <li>Fast and intuitive search experience</li>
                    <li>Modern property detail pages</li>
                    <li>Secure login and account system</li>
                    <li>Responsive design across all devices</li>
                </ul>
            </div>

            <div class="info-page-card">
                <h3>Our vision</h3>
                <p>
                    We aim to build a platform that feels professional, reliable and easy to use.
                   
                </p>
            </div>

            <div class="info-page-card">
                <h3>Why Book4You</h3>
                <p>
                    Clean design, user-centered layout, and scalable structure make the platform a strong base
                    for a modern travel experience.
                </p>
            </div>
        </div>
    </section>
</div>