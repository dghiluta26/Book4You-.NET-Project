@{
    ViewData["Title"] = "Cancellation Policy";
}

<div class="page">
    <section class="page-hero">
        <h1>Cancellation Policy</h1>
        <p>Learn how cancellations and changes are handled on Book4You.</p>
    </section>

    <section class="info-page-section">
        <div class="info-page-container">
            <h2>Policy overview</h2>

            <div class="info-page-card">
                <h3>Standard policy</h3>
                <p>
                    Cancellations should be made as early as possible. In this demo project, the booking flow is
                    simulated, so cancellation rules are shown for reference only.
                </p>
            </div>

            <div class="info-page-card">
                <h3>Before the check-in date</h3>
                <p>
                    If cancellations are allowed for a booking, making a change before check-in is usually the easiest
                    option and may reduce or avoid any fees.
                </p>
            </div>

            <div class="info-page-card">
                <h3>After the check-in date</h3>
                <p>
                    Once the stay has started, cancellations may not be possible. Any refund eligibility depends on the
                    property’s policy and the timing of the request.
                </p>
            </div>

            <div class="info-page-card">
                <h3>Need help with a booking?</h3>
                <p>
                    Contact our support team through the <a asp-controller="Home" asp-action="Contact">Contact</a> page
                    if you need help with a booking or need clarification on a cancellation.
                </p>
            </div>
        </div>
    </section>
</div>