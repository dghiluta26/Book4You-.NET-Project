@model Project.Models.EditProfileViewModel

@{
    ViewData["Title"] = "Edit Profile";
    var defaultAvatar = Url.Content("~/images/users/default-avatar.svg");
    var profilePicture = string.IsNullOrWhiteSpace(Model.ProfilePictureUrl)
        ? defaultAvatar
        : Model.ProfilePictureUrl;
}

<div class="page-hero">
    <h1>Edit Profile</h1>
    <p>Update your account information.</p>
</div>

<div class="profile-page page">
    <div class="profile-layout">
        <section class="profile-card profile-card--summary">
            <div class="profile-avatar profile-avatar--large">
                <img src="@profilePicture" alt="Profile picture preview" onerror="this.onerror=null;this.src='@defaultAvatar';" />
            </div>

            <div class="profile-summary-text">
                <span class="profile-role">Preview</span>
                <h2>@Model.FirstName @Model.LastName</h2>
                <p>Your avatar and details will appear here.</p>
            </div>
        </section>

        <form asp-controller="Account" asp-action="EditProfile" method="post" enctype="multipart/form-data" class="profile-card profile-form">
            <h3>Personal information</h3>

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <label for="FirstName">First Name</label>
            <input id="FirstName" name="FirstName" value="@Model.FirstName" />

            <label for="LastName">Last Name</label>
            <input id="LastName" name="LastName" value="@Model.LastName" />

            <label for="Address">Address</label>
            <input id="Address" name="Address" value="@Model.Address" />

            <button type="submit" class="profile-save-btn">Save changes</button>
        </form>
    </div>
</div>
